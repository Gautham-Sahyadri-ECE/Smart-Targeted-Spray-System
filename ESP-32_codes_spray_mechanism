#include <WiFi.h>
#include <WebServer.h>
#include <ESP32Servo.h>

const char* ssid = "12345678";
const char* password = "12345678";

WebServer server(80);

Servo servoX;
Servo servoY;

int posX = 90;
int posY = 90;

int relayPin = 23;

String webpage = R"====(
<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Spray Control</title>

<style>

body{
font-family:Arial;
text-align:center;
background:#f4f4f4;
}

h2{
margin-top:20px;
}

.grid{
display:grid;
grid-template-columns:100px 100px 100px;
justify-content:center;
gap:10px;
margin-top:40px;
}

button{
height:80px;
font-size:30px;
border:none;
border-radius:15px;
background:#4CAF50;
color:white;
}

button:active{
background:#2e7d32;
}

.pump{
margin-top:40px;
}

</style>
</head>

<body>

<h2>Spray Direction Control</h2>

<div class="grid">

<div></div>
<button onclick="fetch('/up')">↑</button>
<div></div>

<button onclick="fetch('/left')">←</button>
<div></div>
<button onclick="fetch('/right')">→</button>

<div></div>
<button onclick="fetch('/down')">↓</button>
<div></div>

</div>

<div class="pump">

<h2>Pump Control</h2>

<button onclick="fetch('/pump_on')">START SPRAY</button>
<button onclick="fetch('/pump_off')">STOP SPRAY</button>

</div>

</body>
</html>
)====";

void setup(){

Serial.begin(115200);

servoX.attach(18);
servoY.attach(19);

pinMode(relayPin, OUTPUT);
digitalWrite(relayPin, HIGH);

servoX.write(posX);
servoY.write(posY);

WiFi.begin(ssid,password);

while(WiFi.status()!=WL_CONNECTED){
delay(500);
Serial.print(".");
}

Serial.println(WiFi.localIP());

server.on("/",[](){
server.send(200,"text/html",webpage);
});

server.on("/up",[](){
posY+=10;
if(posY>180) posY=180;
servoY.write(posY);
server.send(200,"text/plain","OK");
});

server.on("/down",[](){
posY-=10;
if(posY<0) posY=0;
servoY.write(posY);
server.send(200,"text/plain","OK");
});

server.on("/left",[](){
posX-=10;
if(posX<0) posX=0;
servoX.write(posX);
server.send(200,"text/plain","OK");
});

server.on("/right",[](){
posX+=10;
if(posX>180) posX=180;
servoX.write(posX);
server.send(200,"text/plain","OK");
});

server.on("/pump_on",[](){
digitalWrite(relayPin,LOW);
server.send(200,"text/plain","Pump ON");
});

server.on("/pump_off",[](){
digitalWrite(relayPin,HIGH);
server.send(200,"text/plain","Pump OFF");
});

server.begin();
}

void loop(){
server.handleClient();
}
